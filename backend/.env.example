# Database Configuration
DATABASE_URL=postgresql://drishti_user:your_password@localhost:5432/drishti
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# AI/ML Services
MISTRAL_API_KEY=your-mistral-api-key-here

# Security
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-characters-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Application Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ChromaDB
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=drishti_crimes

# Translation Services (Optional)
GOOGLE_TRANSLATE_API_KEY=your-google-translate-key

# Session Management
SESSION_EXPIRE_MINUTES=60
MAX_SESSION_HISTORY=50

# File Upload
MAX_UPLOAD_SIZE_MB=10

# Monitoring (Optional)
SENTRY_DSN=
PROMETHEUS_ENABLED=false
